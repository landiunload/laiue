+void WorldFormatAbsoluteBlockCoordinate(World* world,
+    int32_t axis, int64_t localBlock, wchar_t* outText, uint32_t capacity)
+{
+    if (axis < 0 || axis >= 3)
+    {
+        if (capacity > 0)
+        {
+            outText[0] = L'\0';
+        }
+        return;
+    }
+
+    InfiniteCoordFormatShortOffsetW(
+        &world->blockOrigin[axis], localBlock, outText, capacity);
+}
