diff --git a/src/celestial/world_calendar.c b/src/celestial/world_calendar.c
new file mode 100644
index 0000000000000000000000000000000000000000..ed902e3ef1f76c997ac579985b49c83b243ab0a4
--- /dev/null
+++ b/src/celestial/world_calendar.c
@@ -0,0 +1,119 @@
+#include "celestial/world_calendar.h"
+
+#include <limits.h>
+
+#define WORLD_EPOCH_2000_TO_1970_DAYS 10957LL
+
+static int64_t FloorDivide(int64_t value, int64_t divisor)
+{
+    int64_t quotient = value / divisor;
+    if (value % divisor < 0)
+    {
+        --quotient;
+    }
+    return quotient;
+}
+
+static int64_t SaturatingAdd(int64_t left, int64_t right)
+{
+    if (right > 0 && left > INT64_MAX - right) return INT64_MAX;
+    if (right < 0 && left < INT64_MIN - right) return INT64_MIN;
+    return left + right;
+}
+
+static void AppendCharacter(wchar_t* destination, uint32_t capacity,
+    uint32_t* length, wchar_t character)
+{
+    if (*length + 1u >= capacity) return;
+    destination[(*length)++] = character;
+    destination[*length] = L'\0';
+}
+
+static void AppendUnsigned(wchar_t* destination, uint32_t capacity,
+    uint32_t* length, uint64_t value, uint32_t minimumDigits)
+{
+    wchar_t reversed[24];
+    uint32_t count = 0;
+    do
+    {
+        reversed[count++] = (wchar_t)(L'0' + value % 10u);
+        value /= 10u;
+    }
+    while (value != 0u && count < 24u);
+    while (count < minimumDigits && count < 24u)
+    {
+        reversed[count++] = L'0';
+    }
+    while (count > 0u)
+    {
+        AppendCharacter(destination, capacity, length, reversed[--count]);
+    }
+}
+
+static void AppendSigned(wchar_t* destination, uint32_t capacity,
+    uint32_t* length, int64_t value)
+{
+    uint64_t magnitude;
+    if (value < 0)
+    {
+        AppendCharacter(destination, capacity, length, L'-');
+        magnitude = (uint64_t)(-(value + 1)) + 1u;
+    }
+    else
+    {
+        magnitude = (uint64_t)value;
+    }
+    AppendUnsigned(destination, capacity, length, magnitude, 1u);
+}
+
+void WorldCalendarGetDateTime(
+    const WorldClock* clock, WorldDateTime* outDateTime)
+{
+    // Howard Hinnant's civil_from_days for the proleptic Gregorian calendar.
+    int64_t z = SaturatingAdd(WorldClockGetDayNumber(clock),
+        WORLD_EPOCH_2000_TO_1970_DAYS);
+    z = SaturatingAdd(z, 719468);
+    int64_t era = FloorDivide(z, 146097);
+    uint32_t dayOfEra = (uint32_t)(z - era * 146097);
+    uint32_t yearOfEra = (dayOfEra - dayOfEra / 1460u
+        + dayOfEra / 36524u - dayOfEra / 146096u) / 365u;
+    int64_t year = (int64_t)yearOfEra + era * 400;
+    uint32_t dayOfYear = dayOfEra
+        - (365u * yearOfEra + yearOfEra / 4u - yearOfEra / 100u);
+    uint32_t monthPrime = (5u * dayOfYear + 2u) / 153u;
+    uint32_t day = dayOfYear
+        - (153u * monthPrime + 2u) / 5u + 1u;
+    uint32_t month = monthPrime < 10u
+        ? monthPrime + 3u : monthPrime - 9u;
+    year += month <= 2u;
+
+    uint32_t seconds = WorldClockGetSecondOfDay(clock);
+    outDateTime->year = year;
+    outDateTime->month = (uint8_t)month;
+    outDateTime->day = (uint8_t)day;
+    outDateTime->hour = (uint8_t)(seconds / 3600u);
+    outDateTime->minute = (uint8_t)((seconds / 60u) % 60u);
+    outDateTime->second = (uint8_t)(seconds % 60u);
+}
+
+void WorldCalendarFormatDateTime(
+    const WorldClock* clock, wchar_t* destination, uint32_t capacity)
+{
+    if (capacity == 0u) return;
+    destination[0] = L'\0';
+
+    WorldDateTime dateTime;
+    WorldCalendarGetDateTime(clock, &dateTime);
+    uint32_t length = 0;
+    AppendSigned(destination, capacity, &length, dateTime.year);
+    AppendCharacter(destination, capacity, &length, L'-');
+    AppendUnsigned(destination, capacity, &length, dateTime.month, 2u);
+    AppendCharacter(destination, capacity, &length, L'-');
+    AppendUnsigned(destination, capacity, &length, dateTime.day, 2u);
+    AppendCharacter(destination, capacity, &length, L' ');
+    AppendUnsigned(destination, capacity, &length, dateTime.hour, 2u);
+    AppendCharacter(destination, capacity, &length, L':');
+    AppendUnsigned(destination, capacity, &length, dateTime.minute, 2u);
+    AppendCharacter(destination, capacity, &length, L':');
+    AppendUnsigned(destination, capacity, &length, dateTime.second, 2u);
+}
