diff --git a/src/celestial/world_clock.c b/src/celestial/world_clock.c
new file mode 100644
index 0000000000000000000000000000000000000000..416733db5a28869115fb6b866174fc7515012510
--- /dev/null
+++ b/src/celestial/world_clock.c
@@ -0,0 +1,121 @@
+#include "celestial/world_clock.h"
+
+#include <limits.h>
+
+#define WORLD_SECONDS_PER_DAY 86400.0
+
+static uint64_t MixSeed(uint64_t value)
+{
+    value ^= value >> 30;
+    value *= UINT64_C(0xbf58476d1ce4e5b9);
+    value ^= value >> 27;
+    value *= UINT64_C(0x94d049bb133111eb);
+    return value ^ (value >> 31);
+}
+
+static int64_t FloorToInt64(double value)
+{
+    int64_t truncated = (int64_t)value;
+    return (double)truncated > value ? truncated - 1 : truncated;
+}
+
+static int64_t SaturatingAdd(int64_t left, int64_t right)
+{
+    if (right > 0 && left > INT64_MAX - right)
+    {
+        return INT64_MAX;
+    }
+    if (right < 0 && left < INT64_MIN - right)
+    {
+        return INT64_MIN;
+    }
+    return left + right;
+}
+
+static void Normalize(WorldClock* clock)
+{
+    if (clock->secondsOfDay >= 0.0
+        && clock->secondsOfDay < WORLD_SECONDS_PER_DAY)
+    {
+        return;
+    }
+
+    int64_t dayDelta = FloorToInt64(
+        clock->secondsOfDay / WORLD_SECONDS_PER_DAY);
+    clock->secondsOfDay -= (double)dayDelta * WORLD_SECONDS_PER_DAY;
+    clock->dayNumber = SaturatingAdd(clock->dayNumber, dayDelta);
+
+    if (clock->secondsOfDay < 0.0)
+    {
+        clock->secondsOfDay += WORLD_SECONDS_PER_DAY;
+        clock->dayNumber = SaturatingAdd(clock->dayNumber, -1);
+    }
+    else if (clock->secondsOfDay >= WORLD_SECONDS_PER_DAY)
+    {
+        clock->secondsOfDay -= WORLD_SECONDS_PER_DAY;
+        clock->dayNumber = SaturatingAdd(clock->dayNumber, 1);
+    }
+}
+
+void WorldClockInit(WorldClock* clock,
+    int64_t seed, double gameSecondsPerRealSecond)
+{
+    uint64_t mixed = MixSeed((uint64_t)seed);
+    // The seed chooses a date inside one complete 400-year Gregorian cycle.
+    // A new world starts at 08:00 so the first session is not forced into night.
+    clock->dayNumber = (int64_t)(mixed % UINT64_C(146097));
+    clock->secondsOfDay = 8.0 * 3600.0;
+    clock->gameSecondsPerRealSecond = gameSecondsPerRealSecond > 0.0
+        ? gameSecondsPerRealSecond : 72.0;
+    clock->running = true;
+}
+
+void WorldClockAdvance(WorldClock* clock, double realSeconds)
+{
+    if (!clock->running || realSeconds <= 0.0)
+    {
+        return;
+    }
+    WorldClockAddGameSeconds(clock,
+        realSeconds * clock->gameSecondsPerRealSecond);
+}
+
+void WorldClockAddGameSeconds(WorldClock* clock, double gameSeconds)
+{
+    clock->secondsOfDay += gameSeconds;
+    Normalize(clock);
+}
+
+void WorldClockSetTimeOfDay(WorldClock* clock,
+    uint32_t hour, uint32_t minute, uint32_t second)
+{
+    if (hour > 23u) hour = 23u;
+    if (minute > 59u) minute = 59u;
+    if (second > 59u) second = 59u;
+    clock->secondsOfDay = (double)(hour * 3600u + minute * 60u + second);
+}
+
+void WorldClockSetRunning(WorldClock* clock, bool running)
+{
+    clock->running = running;
+}
+
+bool WorldClockIsRunning(const WorldClock* clock)
+{
+    return clock->running;
+}
+
+double WorldClockGetDayFraction(const WorldClock* clock)
+{
+    return clock->secondsOfDay / WORLD_SECONDS_PER_DAY;
+}
+
+int64_t WorldClockGetDayNumber(const WorldClock* clock)
+{
+    return clock->dayNumber;
+}
+
+uint32_t WorldClockGetSecondOfDay(const WorldClock* clock)
+{
+    return (uint32_t)clock->secondsOfDay;
+}
