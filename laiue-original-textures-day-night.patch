diff --git a/src/core/sky_renderer.c b/src/core/sky_renderer.c
new file mode 100644
index 0000000000000000000000000000000000000000..4451e88aa586b3ea34189d465ab0e7d93561b216
--- /dev/null
+++ b/src/core/sky_renderer.c
@@ -0,0 +1,197 @@
+#include "core/sky_renderer.h"
+
+#include "core/math.h"
+
+#include <stddef.h>
+
+#define SKY_PI 3.14159265358979323846f
+
+static uint8_t ColorChannel(float value)
+{
+    value = ScalarClamp(value, 0.0f, 1.0f);
+    return (uint8_t)(value * 255.0f + 0.5f);
+}
+
+static uint32_t BodyColor(const CelestialBodyState* body)
+{
+    float intensity = 0.56f + body->brightness * 0.44f;
+    return UiColor(
+        ColorChannel(body->color[0] * intensity),
+        ColorChannel(body->color[1] * intensity),
+        ColorChannel(body->color[2] * intensity), 255u);
+}
+
+static bool ProjectDirection(const float matrix[16],
+    const float direction[3], float outNdc[2])
+{
+    float clipX = direction[0] * matrix[0]
+        + direction[1] * matrix[4] + direction[2] * matrix[8];
+    float clipY = direction[0] * matrix[1]
+        + direction[1] * matrix[5] + direction[2] * matrix[9];
+    float clipW = direction[0] * matrix[3]
+        + direction[1] * matrix[7] + direction[2] * matrix[11];
+    if (clipW <= 1e-5f)
+    {
+        return false;
+    }
+    outNdc[0] = clipX / clipW;
+    outNdc[1] = clipY / clipW;
+    return outNdc[0] >= -1.25f && outNdc[0] <= 1.25f
+        && outNdc[1] >= -1.25f && outNdc[1] <= 1.25f;
+}
+
+static float BodyDiameter(const CelestialBodyState* body,
+    const RendererFrameSetup* frame, float horizontalFovRadians,
+    float targetWidth)
+{
+    float radians = body->angularRadius * 2.0f;
+    float referenceFov = frame->panorama ? SKY_PI * 0.5f
+        : ScalarClamp(horizontalFovRadians, 0.0174533f, 2.96706f);
+    float diameter = radians / referenceFov * targetWidth;
+    return ScalarClamp(diameter, 12.0f, 112.0f);
+}
+
+static void SetRect(RendererUiQuad* quad,
+    float centerX, float centerY, float diameter)
+{
+    float radius = diameter * 0.5f;
+    quad->rect[0] = centerX - radius;
+    quad->rect[1] = centerY - radius;
+    quad->rect[2] = centerX + radius;
+    quad->rect[3] = centerY + radius;
+    quad->reserved = 0u;
+}
+
+static bool AddBody(const CelestialBodyState* body,
+    const RendererFrameSetup* frame, uint32_t passIndex,
+    float horizontalFovRadians, const UiAtlasRegion* sprite,
+    RendererUiQuad* outQuad)
+{
+    if (body->visible == 0u || body->brightness <= 0.01f)
+    {
+        return false;
+    }
+
+    const RendererScenePass* pass = &frame->passes[passIndex];
+    float ndc[2];
+    if (!ProjectDirection(pass->viewProjection, body->direction, ndc))
+    {
+        return false;
+    }
+
+    float targetWidth;
+    float targetHeight;
+    float left;
+    float top;
+    if (frame->panorama)
+    {
+        // Scene UI is drawn with the pass viewport still active, therefore
+        // coordinates are local to that off-center viewport, not to the full
+        // cube-face texture.
+        targetWidth = (float)(pass->rectMaxX - pass->rectMinX);
+        targetHeight = (float)(pass->rectMaxY - pass->rectMinY);
+        left = 0.0f;
+        top = 0.0f;
+    }
+    else
+    {
+        targetWidth = (float)pass->rectMaxX;
+        targetHeight = (float)pass->rectMaxY;
+        left = 0.0f;
+        top = 0.0f;
+    }
+
+    float centerX = left + (ndc[0] * 0.5f + 0.5f) * targetWidth;
+    float centerY = top + (0.5f - ndc[1] * 0.5f) * targetHeight;
+    float diameter = BodyDiameter(body, frame, horizontalFovRadians,
+        targetWidth);
+    SetRect(outQuad, centerX, centerY, diameter);
+    outQuad->colorRGBA = BodyColor(body);
+
+    if (sprite != NULL)
+    {
+        outQuad->uv[0] = sprite->u0;
+        outQuad->uv[1] = sprite->v0;
+        outQuad->uv[2] = sprite->u1;
+        outQuad->uv[3] = sprite->v1;
+        outQuad->cornerRadius = 0.0f;
+        outQuad->flags = RENDERER_UI_QUAD_TEXT;
+    }
+    else
+    {
+        outQuad->uv[0] = outQuad->uv[1]
+            = outQuad->uv[2] = outQuad->uv[3] = 0.0f;
+        outQuad->cornerRadius = diameter * 0.5f;
+        outQuad->flags = 0u;
+    }
+    return true;
+}
+
+uint32_t SkyRendererBuildPassQuads(const CelestialState* celestial,
+    const RendererFrameSetup* frame, uint32_t passIndex,
+    float horizontalFovRadians, const UiFont* atlas,
+    RendererUiQuad outQuads[SKY_RENDERER_MAX_PASS_QUADS])
+{
+    if (passIndex >= frame->passCount)
+    {
+        return 0u;
+    }
+
+    uint32_t count = 0u;
+    if (AddBody(&celestial->sun, frame, passIndex,
+            horizontalFovRadians, NULL, &outQuads[count]))
+    {
+        ++count;
+    }
+
+    const UiAtlasRegion* lima = &atlas->moonPhases[0]
+        [celestial->lima.phaseIndex & 7u];
+    if (AddBody(&celestial->lima, frame, passIndex,
+            horizontalFovRadians, lima, &outQuads[count]))
+    {
+        ++count;
+    }
+
+    const UiAtlasRegion* pox = &atlas->moonPhases[1]
+        [celestial->pox.phaseIndex & 7u];
+    if (AddBody(&celestial->pox, frame, passIndex,
+            horizontalFovRadians, pox, &outQuads[count]))
+    {
+        ++count;
+    }
+    return count;
+}
+
+void SkyRendererQueueLightingOverlay(UiContext* ui,
+    const CelestialState* celestial, int32_t width, int32_t height)
+{
+    float light = (celestial->sceneLight[0]
+        + celestial->sceneLight[1] + celestial->sceneLight[2]) / 3.0f;
+    float darkness = ScalarClamp(1.0f - light, 0.0f, 1.0f);
+    uint32_t alpha = (uint32_t)(darkness * 178.0f + 0.5f);
+    if (alpha == 0u)
+    {
+        return;
+    }
+    if (ui->quadCount >= UI_MAX_DRAW_QUADS)
+    {
+        return;
+    }
+    // Insert the lighting filter below existing menu quads. PauseMenuUpdate may
+    // already have appended its controls by the time celestial state is known.
+    for (uint32_t index = ui->quadCount; index > 0u; --index)
+    {
+        ui->quads[index] = ui->quads[index - 1u];
+    }
+    RendererUiQuad* quad = &ui->quads[0];
+    quad->rect[0] = 0.0f;
+    quad->rect[1] = 0.0f;
+    quad->rect[2] = (float)width;
+    quad->rect[3] = (float)height;
+    quad->uv[0] = quad->uv[1] = quad->uv[2] = quad->uv[3] = 0.0f;
+    quad->colorRGBA = UiColor(3u, 7u, 22u, alpha);
+    quad->cornerRadius = 0.0f;
+    quad->flags = 0u;
+    quad->reserved = 0u;
+    ui->quadCount++;
+}
