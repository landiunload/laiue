diff --git a/src/celestial/celestial_model.c b/src/celestial/celestial_model.c
new file mode 100644
index 0000000000000000000000000000000000000000..20d977a27fbb3351d4defccfe65b7eac53fa5457
--- /dev/null
+++ b/src/celestial/celestial_model.c
@@ -0,0 +1,197 @@
+#include "celestial/celestial_model.h"
+
+#include <stdbool.h>
+
+#define CELESTIAL_PI 3.14159265358979323846
+#define CELESTIAL_TWO_PI (2.0 * CELESTIAL_PI)
+#define WORLD_SECONDS_PER_DAY_INT 86400LL
+#define LIMA_PERIOD_SECONDS 2551443LL
+#define POX_PERIOD_SECONDS 1004832LL
+
+static uint64_t MixSeed(uint64_t value)
+{
+    value ^= value >> 30;
+    value *= UINT64_C(0xbf58476d1ce4e5b9);
+    value ^= value >> 27;
+    value *= UINT64_C(0x94d049bb133111eb);
+    return value ^ (value >> 31);
+}
+
+static double WrapSignedPi(double value)
+{
+    while (value > CELESTIAL_PI) value -= CELESTIAL_TWO_PI;
+    while (value < -CELESTIAL_PI) value += CELESTIAL_TWO_PI;
+    return value;
+}
+
+static double SinApprox(double value)
+{
+    value = WrapSignedPi(value);
+    if (value > CELESTIAL_PI * 0.5)
+    {
+        value = CELESTIAL_PI - value;
+    }
+    else if (value < -CELESTIAL_PI * 0.5)
+    {
+        value = -CELESTIAL_PI - value;
+    }
+
+    double square = value * value;
+    return value * (1.0 + square * (-1.0 / 6.0
+        + square * (1.0 / 120.0
+        + square * (-1.0 / 5040.0
+        + square * (1.0 / 362880.0)))));
+}
+
+static double CosApprox(double value)
+{
+    return SinApprox(value + CELESTIAL_PI * 0.5);
+}
+
+static float Clamp01(float value)
+{
+    if (value < 0.0f) return 0.0f;
+    if (value > 1.0f) return 1.0f;
+    return value;
+}
+
+static float SmoothStep(float edge0, float edge1, float value)
+{
+    float t = Clamp01((value - edge0) / (edge1 - edge0));
+    return t * t * (3.0f - 2.0f * t);
+}
+
+static float Lerp(float left, float right, float amount)
+{
+    return left + (right - left) * amount;
+}
+
+static int64_t PositiveModulo(int64_t value, int64_t modulus)
+{
+    int64_t result = value % modulus;
+    return result < 0 ? result + modulus : result;
+}
+
+static double CycleFraction(const WorldClock* clock,
+    int64_t periodSeconds, uint64_t seedOffset)
+{
+    int64_t dayRemainder = PositiveModulo(
+        WorldClockGetDayNumber(clock), periodSeconds);
+    int64_t wholeSeconds = (int64_t)clock->secondsOfDay;
+    int64_t cycle = PositiveModulo(
+        dayRemainder * WORLD_SECONDS_PER_DAY_INT
+            + wholeSeconds
+            + (int64_t)(seedOffset % (uint64_t)periodSeconds),
+        periodSeconds);
+    double fraction = ((double)cycle
+        + (clock->secondsOfDay - (double)wholeSeconds))
+        / (double)periodSeconds;
+    return fraction >= 1.0 ? fraction - 1.0 : fraction;
+}
+
+static void SetOrbitDirection(float outDirection[3],
+    double longitude, double inclination)
+{
+    double sinLongitude = SinApprox(longitude);
+    double cosLongitude = CosApprox(longitude);
+    double sinInclination = SinApprox(inclination);
+    double cosInclination = CosApprox(inclination);
+
+    outDirection[0] = (float)cosLongitude;
+    outDirection[1] = (float)(-sinLongitude * sinInclination);
+    outDirection[2] = (float)(sinLongitude * cosInclination);
+}
+
+static uint32_t PhaseIndex(double fraction)
+{
+    uint32_t index = (uint32_t)(fraction * 8.0 + 0.5);
+    return index & 7u;
+}
+
+static float PhaseBrightness(double fraction)
+{
+    return (float)(0.12 + 0.88
+        * (0.5 - 0.5 * CosApprox(fraction * CELESTIAL_TWO_PI)));
+}
+
+static void SetBody(CelestialBodyState* body,
+    double longitude, double inclination, double phase,
+    float red, float green, float blue,
+    float angularRadius, bool isSun)
+{
+    SetOrbitDirection(body->direction, longitude, inclination);
+    body->color[0] = red;
+    body->color[1] = green;
+    body->color[2] = blue;
+    body->angularRadius = angularRadius;
+    body->phaseIndex = isSun ? 0u : PhaseIndex(phase);
+    body->brightness = isSun ? 1.0f : PhaseBrightness(phase);
+    body->visible = body->direction[2] > -0.08f ? 1u : 0u;
+}
+
+void CelestialEvaluate(const WorldClock* clock,
+    int64_t seed, CelestialState* outState)
+{
+    double dayFraction = WorldClockGetDayFraction(clock);
+    // 06:00 — восточный горизонт, 12:00 — зенит, 18:00 — запад.
+    double sunLongitude = (dayFraction - 0.25) * CELESTIAL_TWO_PI;
+
+    uint64_t mixed = MixSeed((uint64_t)seed);
+    double limaPhase = CycleFraction(clock, LIMA_PERIOD_SECONDS, mixed);
+    double poxPhase = CycleFraction(clock, POX_PERIOD_SECONDS,
+        MixSeed(mixed ^ UINT64_C(0x706f785f6d6f6f6e)));
+
+    SetBody(&outState->sun,
+        sunLongitude, 0.0, 0.0,
+        1.0f, 0.84f, 0.48f, 0.045f, true);
+    SetBody(&outState->lima,
+        sunLongitude + limaPhase * CELESTIAL_TWO_PI,
+        0.16, limaPhase,
+        0.86f, 0.92f, 1.0f, 0.038f, false);
+    SetBody(&outState->pox,
+        sunLongitude + poxPhase * CELESTIAL_TWO_PI,
+        -0.31, poxPhase,
+        1.0f, 0.62f, 0.38f, 0.030f, false);
+
+    float sunElevation = outState->sun.direction[2];
+    float daylight = SmoothStep(-0.16f, 0.16f, sunElevation);
+    float twilight = 1.0f - SmoothStep(0.02f, 0.34f,
+        sunElevation < 0.0f ? -sunElevation : sunElevation);
+
+    const float night[3] = { 0.008f, 0.014f, 0.040f };
+    const float day[3] = { 0.38f, 0.63f, 0.92f };
+    const float sunset[3] = { 0.78f, 0.27f, 0.12f };
+    for (uint32_t channel = 0; channel < 3u; ++channel)
+    {
+        float base = Lerp(night[channel], day[channel], daylight);
+        outState->skyColor[channel] = Clamp01(
+            base + sunset[channel] * twilight * (1.0f - daylight) * 0.42f);
+    }
+    outState->skyColor[3] = 1.0f;
+
+    float limaLight = outState->lima.brightness
+        * Clamp01(outState->lima.direction[2]) * 0.10f;
+    float poxLight = outState->pox.brightness
+        * Clamp01(outState->pox.direction[2]) * 0.07f;
+    float nightContribution = (limaLight + poxLight) * (1.0f - daylight);
+    float light = Clamp01(0.11f + daylight * 0.89f + nightContribution);
+    outState->sceneLight[0] = light * Lerp(0.62f, 1.0f, daylight);
+    outState->sceneLight[1] = light * Lerp(0.70f, 1.0f, daylight);
+    outState->sceneLight[2] = light * Lerp(0.95f, 1.0f, daylight);
+    outState->sceneLight[3] = 1.0f;
+}
+
+const wchar_t* CelestialPhaseName(uint32_t phaseIndex)
+{
+    static const wchar_t* const names[8] = {
+        L"новолуние",
+        L"растущий серп",
+        L"первая четверть",
+        L"растущая",
+        L"полнолуние",
+        L"убывающая",
+        L"последняя четверть",
+        L"убывающий серп",
+    };
+    return names[phaseIndex & 7u];
+}
