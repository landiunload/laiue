+#pragma once
+
+#include <stdbool.h>
+#include <stdint.h>
+
+#define UI_MOON_ATLAS_WIDTH 256u
+#define UI_MOON_ATLAS_HEIGHT 64u
+#define UI_MOON_SPRITE_SIZE 32u
+#define UI_MOON_BODY_COUNT 2u
+#define UI_MOON_PHASE_COUNT 8u
+
+// Copies the generated Lima/Pox phase atlas into an existing R8 UI atlas.
+// Missing runtime data is non-fatal: a procedural phase fallback is written.
+bool UiAtlasAssetsWriteMoonPhases(uint8_t* atlas,
+    uint32_t atlasWidth, uint32_t atlasHeight,
+    uint32_t destinationX, uint32_t destinationY);
