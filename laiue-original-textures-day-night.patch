diff --git a/src/core/ui_atlas_assets.c b/src/core/ui_atlas_assets.c
new file mode 100644
index 0000000000000000000000000000000000000000..c49b0b553442748ab449d081cff6ab75f7318a39
--- /dev/null
+++ b/src/core/ui_atlas_assets.c
@@ -0,0 +1,141 @@
+#include "core/ui_atlas_assets.h"
+
+#include <windows.h>
+#include <stddef.h>
+
+#define MOON_BYTES (UI_MOON_ATLAS_WIDTH * UI_MOON_ATLAS_HEIGHT)
+#define PATH_CAPACITY 32768u
+
+static bool GetAssetPath(wchar_t* path, uint32_t capacity)
+{
+    DWORD length = GetModuleFileNameW(NULL, path, capacity);
+    if (length == 0u || length >= capacity)
+    {
+        return false;
+    }
+    while (length > 0u && path[length - 1u] != L'\\'
+        && path[length - 1u] != L'/')
+    {
+        --length;
+    }
+    static const wchar_t suffix[] = L"sky\\moons_32x8.r8";
+    uint32_t suffixLength = (uint32_t)(sizeof(suffix) / sizeof(suffix[0])) - 1u;
+    if (length + suffixLength + 1u > capacity)
+    {
+        return false;
+    }
+    for (uint32_t index = 0; index <= suffixLength; ++index)
+    {
+        path[length + index] = suffix[index];
+    }
+    return true;
+}
+
+static bool ReadGeneratedAtlas(uint8_t pixels[MOON_BYTES])
+{
+    wchar_t* path = HeapAlloc(GetProcessHeap(), 0,
+        (size_t)PATH_CAPACITY * sizeof(wchar_t));
+    if (path == NULL || !GetAssetPath(path, PATH_CAPACITY))
+    {
+        if (path != NULL) HeapFree(GetProcessHeap(), 0, path);
+        return false;
+    }
+
+    HANDLE file = CreateFileW(path, GENERIC_READ,
+        FILE_SHARE_READ | FILE_SHARE_WRITE | FILE_SHARE_DELETE,
+        NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
+    HeapFree(GetProcessHeap(), 0, path);
+    if (file == INVALID_HANDLE_VALUE)
+    {
+        return false;
+    }
+
+    LARGE_INTEGER size;
+    DWORD read = 0;
+    bool succeeded = GetFileSizeEx(file, &size)
+        && size.QuadPart == MOON_BYTES
+        && ReadFile(file, pixels, MOON_BYTES, &read, NULL)
+        && read == MOON_BYTES;
+    CloseHandle(file);
+    return succeeded;
+}
+
+static int32_t Absolute(int32_t value)
+{
+    return value < 0 ? -value : value;
+}
+
+static void BuildFallback(uint8_t pixels[MOON_BYTES])
+{
+    for (uint32_t body = 0; body < UI_MOON_BODY_COUNT; ++body)
+    {
+        for (uint32_t phase = 0; phase < UI_MOON_PHASE_COUNT; ++phase)
+        {
+            uint32_t frameOffset =
+                (body * UI_MOON_PHASE_COUNT + phase)
+                * UI_MOON_SPRITE_SIZE * UI_MOON_SPRITE_SIZE;
+            for (int32_t y = 0; y < (int32_t)UI_MOON_SPRITE_SIZE; ++y)
+            {
+                for (int32_t x = 0; x < (int32_t)UI_MOON_SPRITE_SIZE; ++x)
+                {
+                    int32_t dx = x * 2 - 31;
+                    int32_t dy = y * 2 - 31;
+                    uint8_t alpha = 0;
+                    if (dx * dx + dy * dy <= 29 * 29)
+                    {
+                        // Eight readable fallback phases. The shipped generated
+                        // atlas replaces this path during normal builds.
+                        int32_t terminator = (int32_t)phase * 8 - 28;
+                        bool lit = phase <= 4u
+                            ? dx >= -terminator
+                            : dx <= 36 - terminator;
+                        if (phase == 0u) lit = false;
+                        if (phase == 4u) lit = true;
+                        alpha = lit ? (uint8_t)(210 + body * 25u) : 18u;
+                        if (((Absolute(dx) + Absolute(dy) + (int32_t)body * 3) % 11) == 0)
+                        {
+                            alpha = (uint8_t)(alpha * 3u / 4u);
+                        }
+                    }
+                    pixels[frameOffset + (uint32_t)y * UI_MOON_SPRITE_SIZE
+                        + (uint32_t)x] = alpha;
+                }
+            }
+        }
+    }
+}
+
+bool UiAtlasAssetsWriteMoonPhases(uint8_t* atlas,
+    uint32_t atlasWidth, uint32_t atlasHeight,
+    uint32_t destinationX, uint32_t destinationY)
+{
+    if (atlas == NULL
+        || destinationX + UI_MOON_ATLAS_WIDTH > atlasWidth
+        || destinationY + UI_MOON_ATLAS_HEIGHT > atlasHeight)
+    {
+        return false;
+    }
+
+    uint8_t* pixels = HeapAlloc(GetProcessHeap(), 0, MOON_BYTES);
+    if (pixels == NULL)
+    {
+        return false;
+    }
+    if (!ReadGeneratedAtlas(pixels))
+    {
+        BuildFallback(pixels);
+    }
+
+    for (uint32_t row = 0; row < UI_MOON_ATLAS_HEIGHT; ++row)
+    {
+        uint8_t* destination = atlas
+            + (size_t)(destinationY + row) * atlasWidth + destinationX;
+        const uint8_t* source = pixels + (size_t)row * UI_MOON_ATLAS_WIDTH;
+        for (uint32_t column = 0; column < UI_MOON_ATLAS_WIDTH; ++column)
+        {
+            destination[column] = source[column];
+        }
+    }
+    HeapFree(GetProcessHeap(), 0, pixels);
+    return true;
+}
diff --git a/src/core/ui_atlas_assets.h b/src/core/ui_atlas_assets.h
