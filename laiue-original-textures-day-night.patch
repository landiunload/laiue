+static void AppendUnsigned64(wchar_t* destination, uint32_t capacity,
+    uint32_t* length, uint64_t value)
+{
+    wchar_t reversedDigits[20];
+    uint32_t digitCount = 0;
+    do
+    {
+        reversedDigits[digitCount++] = (wchar_t)(L'0' + value % 10u);
+        value /= 10u;
+    }
+    while (value != 0u && digitCount < 20u);
+    while (digitCount > 0u && *length + 1u < capacity)
+    {
+        destination[(*length)++] = reversedDigits[--digitCount];
+    }
+    if (capacity > 0u) destination[*length] = L'\0';
 }
 
