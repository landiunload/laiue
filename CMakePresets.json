{
    "version": 8,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "visual-studio",
            "displayName": "Visual Studio (последняя установленная)",
            "inherits": "windows-base"
        },
        {
            "name": "ninja-base",
            "hidden": true,
            "inherits": "windows-base",
            "generator": "Ninja"
        },
        {
            "name": "ninja-msvc-debug",
            "displayName": "Ninja + MSVC Debug",
            "inherits": "ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe"
            }
        },
        {
            "name": "ninja-msvc-release",
            "displayName": "Ninja + MSVC Release",
            "inherits": "ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "cl.exe"
            }
        },
        {
            "name": "ninja-clang-debug",
            "displayName": "Ninja + Clang Debug",
            "inherits": "ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang-cl.exe"
            }
        },
        {
            "name": "ninja-clang-release",
            "displayName": "Ninja + Clang Release",
            "inherits": "ninja-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang-cl.exe"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "visual-studio-debug",
            "configurePreset": "visual-studio",
            "configuration": "Debug"
        },
        {
            "name": "visual-studio-release",
            "configurePreset": "visual-studio",
            "configuration": "Release"
        },
        {
            "name": "ninja-msvc-debug",
            "configurePreset": "ninja-msvc-debug"
        },
        {
            "name": "ninja-msvc-release",
            "configurePreset": "ninja-msvc-release"
        },
        {
            "name": "ninja-clang-debug",
            "configurePreset": "ninja-clang-debug"
        },
        {
            "name": "ninja-clang-release",
            "configurePreset": "ninja-clang-release"
        }
    ],
    "testPresets": [
        {
            "name": "visual-studio-debug",
            "configurePreset": "visual-studio",
            "configuration": "Debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "visual-studio-release",
            "configurePreset": "visual-studio",
            "configuration": "Release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ninja-msvc-debug",
            "configurePreset": "ninja-msvc-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ninja-msvc-release",
            "configurePreset": "ninja-msvc-release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ninja-clang-debug",
            "configurePreset": "ninja-clang-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "ninja-clang-release",
            "configurePreset": "ninja-clang-release",
            "output": { "outputOnFailure": true }
        }
    ]
}
